---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";

const allEntries = await getCollection("knowledgebase");

// Filter out drafts
const entries = allEntries
  .filter((e) => e.data.draft !== true)
  .map((e) => ({
    title: e.data.title,
    url: e.data.url,
    source: e.data.source,
    tags: e.data.tags,
    date: e.data.date ? e.data.date.toISOString().split("T")[0] : "",
    description: e.data.description,
  }))
  .sort((a, b) => b.date.localeCompare(a.date));

// Collect all unique tags for filter UI
const allTags = [...new Set(entries.flatMap((e) => e.tags))].sort();
---

<Base
  title="Knowledge Base"
  meta_title="Knowledge Base — adaniels.xyz"
  description="A curated reading archive — articles, links, and notes on AI, crypto, finance, dev, and tech."
>
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8">
          <h1 class="mb-4">Knowledge Base</h1>
          <p class="mb-8 text-lg">
            A running archive of articles, links, and things worth saving — spanning AI, crypto, finance, dev, and whatever else catches my attention.
          </p>

          <!-- Search bar -->
          <div class="mb-6">
            <input
              id="kb-search"
              type="text"
              placeholder="Search entries..."
              class="w-full px-4 py-2 rounded-lg border border-border bg-body dark:bg-darkmode-body focus:outline-none focus:border-primary transition-colors"
            />
          </div>

          <!-- Tag filters -->
          <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
            <button
              data-tag="all"
              class="tag-btn px-3 py-1 rounded-full text-xs border border-primary bg-primary text-white transition-colors"
            >
              all
            </button>
            {
              allTags.map((tag) => (
                <button
                  data-tag={tag}
                  class="tag-btn px-3 py-1 rounded-full text-xs border border-border hover:border-primary transition-colors"
                >
                  {tag}
                </button>
              ))
            }
          </div>

          <!-- Entry list -->
          <div class="space-y-6" id="kb-entries">
            {
              entries.map((entry) => (
                <div
                  class="kb-entry border border-border rounded-lg p-5 hover:border-primary transition-colors"
                  data-tags={entry.tags.join(",")}
                  data-title={entry.title.toLowerCase()}
                  data-source={entry.source.toLowerCase()}
                >
                  <a
                    href={entry.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium hover:text-primary leading-snug block mb-2"
                  >
                    {entry.title}
                  </a>
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="text-xs text-muted">{entry.source}</span>
                    {entry.date && (
                      <span class="text-xs text-muted">{entry.date}</span>
                    )}
                    <div class="flex flex-wrap gap-1 ml-auto">
                      {entry.tags.map((tag) => (
                        <span class="px-2 py-0.5 rounded-full text-xs bg-theme-light dark:bg-darkmode-theme-light text-muted">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Empty state -->
          <div id="kb-empty" class="hidden text-center py-12 text-muted">
            <p>No entries match your search or filter.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const entries = document.querySelectorAll<HTMLElement>(".kb-entry");
  const searchInput = document.getElementById("kb-search") as HTMLInputElement;
  const emptyState = document.getElementById("kb-empty") as HTMLElement;
  let activeTag = "all";
  let searchQuery = "";

  function filterEntries() {
    let visibleCount = 0;

    entries.forEach((entry) => {
      const tags = (entry.dataset.tags ?? "").split(",");
      const title = (entry.dataset.title ?? "");
      const source = (entry.dataset.source ?? "");
      const q = searchQuery.toLowerCase();

      const matchesTag = activeTag === "all" || tags.includes(activeTag);
      const matchesSearch =
        q === "" || title.includes(q) || source.includes(q) || tags.some((t) => t.includes(q));

      if (matchesTag && matchesSearch) {
        entry.style.display = "";
        visibleCount++;
      } else {
        entry.style.display = "none";
      }
    });

    emptyState.classList.toggle("hidden", visibleCount > 0);
  }

  // Tag filter clicks
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag ?? "all";
      activeTag = tag;

      // Update button styles
      buttons.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "border-primary");
        b.classList.add("border-border");
      });
      btn.classList.add("bg-primary", "text-white", "border-primary");
      btn.classList.remove("border-border");

      filterEntries();
    });
  });

  // Text search
  searchInput?.addEventListener("input", () => {
    searchQuery = searchInput.value;
    filterEntries();
  });
</script>