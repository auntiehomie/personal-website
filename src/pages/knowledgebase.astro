---
import Base from "@/layouts/Base.astro";

const entries = [
  {
    title: "Pentagon Disturbed as Its Fleet of Drones Is Left Bobbing in the Ocean When Elon Musk's Starlink Fails",
    url: "https://futurism.com/space/pentagon-starlink-musk-drones",
    source: "futurism.com",
    tags: ["tech", "military"],
    date: "",
  },
  {
    title: "r/ClassActionSettlement — Getting Started",
    url: "https://reddit.com/r/classactionsettlement/wiki/getting-started",
    source: "reddit.com",
    tags: ["legal"],
    date: "",
  },
  {
    title: "The Financial Product That Blew Up the Global Economy Is Back",
    url: "https://newrepublic.com/article/209166/credit-default-swaps-financial-crisis",
    source: "newrepublic.com",
    tags: ["finance"],
    date: "",
  },
  {
    title: "How a quantum computer can be used to actually steal your bitcoin in '9 minutes'",
    url: "https://www.coindesk.com/tech/2026/04/18/how-a-quantum-computer-can-be-used-to-actually-steal-your-bitcoin-in-9-minutes",
    source: "coindesk.com",
    tags: ["crypto", "quantum"],
    date: "",
  },
  {
    title: "I built my entire second brain inside VS Code and stopped switching apps entirely",
    url: "https://flip.it/ZIaXsN",
    source: "flip.it",
    tags: ["productivity", "tools"],
    date: "",
  },
  {
    title: "FIP: Proof of Quality — Farcaster Discussion",
    url: "https://github.com/orgs/farcasterorg/discussions/17",
    source: "github.com",
    tags: ["farcaster", "web3"],
    date: "",
  },
  {
    title: "Palantir employees are starting to wonder if they're the bad guys",
    url: "https://www.wired.com/story/palantir-employees-are-starting-to-wonder-if-theyre-the-bad-guys/",
    source: "wired.com",
    tags: ["tech", "politics"],
    date: "",
  },
  {
    title: "Claude-powered AI coding agent deletes entire company database in 9 seconds",
    url: "https://www.tomshardware.com/tech-industry/artificial-intelligence/claude-powered-ai-coding-agent-deletes-entire-company-database-in-9-seconds-backups-zapped-after-cursor-tool-powered-by-anthropics-claude-goes-rogue",
    source: "tomshardware.com",
    tags: ["ai", "tools"],
    date: "",
  },
  {
    title: "Claude is a space to think",
    url: "https://www.anthropic.com/news/claude-is-a-space-to-think",
    source: "anthropic.com",
    tags: ["ai"],
    date: "",
  },
  {
    title: "Why TUIs are back",
    url: "https://wiki.alcidesfonseca.com/blog/why-tuis-are-back/",
    source: "alcidesfonseca.com",
    tags: ["dev", "tools"],
    date: "",
  },
  {
    title: "Introduction — Electron",
    url: "https://electronjs.org/docs/latest/",
    source: "electronjs.org",
    tags: ["dev"],
    date: "",
  },
  {
    title: "Elon Musk, Sam Altman and the world's billionaires are terrified of the Google AI genius behind a 25-year-old computer game",
    url: "https://www.pcgamer.com/software/ai/elon-musk-sam-altman-and-the-worlds-billionaires-are-terrified-of-the-google-ai-genius-behind-a-25-year-old-computer-game-because-they-think-he-might-actually-end-up-controlling-god/",
    source: "pcgamer.com",
    tags: ["ai", "agi", "tech"],
    date: "2026-05-14",
  },
];

// Collect all unique tags for filter UI
const allTags = [...new Set(entries.flatMap((e) => e.tags))].sort();
---

<Base
  title="Knowledge Base"
  meta_title="Knowledge Base — adaniels.xyz"
  description="A curated reading archive — articles, links, and notes on AI, crypto, finance, dev, and tech."
>
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8">
          <h1 class="mb-4">Knowledge Base</h1>
          <p class="mb-8 text-lg">
            A running archive of articles, links, and things worth saving — spanning AI, crypto, finance, dev, and whatever else catches my attention.
          </p>

          <!-- Tag filters -->
          <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
            <button
              data-tag="all"
              class="tag-btn px-3 py-1 rounded-full text-xs border border-primary bg-primary text-white transition-colors"
            >
              all
            </button>
            {
              allTags.map((tag) => (
                <button
                  data-tag={tag}
                  class="tag-btn px-3 py-1 rounded-full text-xs border border-border hover:border-primary transition-colors"
                >
                  {tag}
                </button>
              ))
            }
          </div>

          <!-- Entry list -->
          <div class="space-y-6" id="kb-entries">
            {
              entries.map((entry) => (
                <div
                  class="kb-entry border border-border rounded-lg p-5 hover:border-primary transition-colors"
                  data-tags={entry.tags.join(",")}
                >
                  <a
                    href={entry.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium hover:text-primary leading-snug block mb-2"
                  >
                    {entry.title}
                  </a>
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="text-xs text-muted">{entry.source}</span>
                    {entry.date && (
                      <span class="text-xs text-muted">{entry.date}</span>
                    )}
                    <div class="flex flex-wrap gap-1 ml-auto">
                      {entry.tags.map((tag) => (
                        <span class="px-2 py-0.5 rounded-full text-xs bg-theme-light dark:bg-darkmode-theme-light text-muted">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const entries = document.querySelectorAll<HTMLElement>(".kb-entry");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag ?? "all";

      // Update button styles
      buttons.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "border-primary");
        b.classList.add("border-border");
      });
      btn.classList.add("bg-primary", "text-white", "border-primary");
      btn.classList.remove("border-border");

      // Filter entries
      entries.forEach((entry) => {
        const tags = (entry.dataset.tags ?? "").split(",");
        if (tag === "all" || tags.includes(tag)) {
          entry.style.display = "";
        } else {
          entry.style.display = "none";
        }
      });
    });
  });
</script>
