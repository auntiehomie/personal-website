---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Resume"
  meta_title="Resume — adaniels.xyz"
  description="Experience and background."
>
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8">
          <h1 class="mb-2">Resume</h1>
          <p class="mb-4 text-muted">
            <a
              href="https://github.com/auntiehomie"
              target="_blank"
              rel="noopener"
              class="hover:text-primary">github.com/auntiehomie</a
            >
          </p>

          <p class="mb-12 text-sm">
            Builder and developer focused on financial tools, DeFi automation, and web apps. I build things that are useful — bots, intelligence tools, and this site itself, which serves as a central hub for my projects, writing, and reading.
          </p>

          <!-- Education -->
          <div class="mb-12">
            <h2 class="h4 border-b border-border pb-2 mb-6">Education</h2>
            <div class="mb-4">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Bachelor of Science — Philosophy</h3>
                <span class="text-sm text-muted">May 2009</span>
              </div>
              <p class="text-sm text-muted">Central Michigan University — Mount Pleasant, MI</p>
            </div>
          </div>

          <!-- Skills -->
          <div class="mb-12">
            <h2 class="h4 border-b border-border pb-2 mb-6">Skills</h2>
            <div class="row">
              <div class="sm:col-6 mb-4">
                <h3 class="h6 mb-2">Languages</h3>
                <p class="text-sm">TypeScript, JavaScript, Python, Solidity, SQL</p>
              </div>
              <div class="sm:col-6 mb-4">
                <h3 class="h6 mb-2">Frameworks & Tools</h3>
                <p class="text-sm">Node.js, Astro, React, Prisma, Docker</p>
              </div>
              <div class="sm:col-6 mb-4">
                <h3 class="h6 mb-2">Blockchain</h3>
                <p class="text-sm">Solana, Ethereum, DeFi protocols, on-chain monitoring</p>
              </div>
              <div class="sm:col-6 mb-4">
                <h3 class="h6 mb-2">Infra & Cloud</h3>
                <p class="text-sm">Vercel, Cloudflare, Render, GitHub Actions</p>
              </div>
              <div class="sm:col-6 mb-4">
                <h3 class="h6 mb-2">General</h3>
                <p class="text-sm">5+ years management, 15+ years sales & customer service, Microsoft Office Suite</p>
              </div>
            </div>
          </div>

          <!-- Professional Experience -->
          <div class="mb-12">
            <h2 class="h4 border-b border-border pb-2 mb-6">Professional Experience</h2>

            <!-- Independent Developer -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Independent Developer</h3>
                <span class="text-sm text-muted">2023 — Present</span>
              </div>
              <p class="text-sm text-muted mb-2">Self-directed / Open Source</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Built and maintain BankBud — a chat-based banking intelligence and rate-tracking tool</li>
                <li>Built Liquidation Bot — real-time DeFi on-chain liquidation monitor and executor</li>
                <li>Built Meteora LP Bot — automated liquidity provision on Solana</li>
                <li>Researching Solana arbitrage strategies and on-chain MEV patterns</li>
                <li>Built and maintain adaniels.xyz — personal site covering projects, resume, reading, and writing</li>
              </ul>
            </div>

            <!-- Assistant Branch Leader - Flagstar -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Assistant Branch Leader</h3>
                <span class="text-sm text-muted">August 2023 — Present</span>
              </div>
              <p class="text-sm text-muted mb-2">Flagstar Bank — Farmington Hills, MI</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Leads branch operations with a strong emphasis on regulatory compliance, operational excellence, and adherence to Flagstar Bank policies, ensuring audit readiness and risk mitigation.</li>
                <li>Cultivated strong relationships with business clients in partnership with Flagstar's Small Business Consultants.</li>
                <li>Drives team performance by coaching staff on the Flagstar Conversational sales approach, improving client engagement, sales effectiveness, and service delivery.</li>
                <li>Partners cross-functionally with operations and compliance leaders to proactively identify and mitigate risk, strengthening internal controls and supporting a culture of accountability.</li>
                <li>Recognized as branch Loan Champion, consistently generating a majority share of loan production and contributing to revenue growth.</li>
              </ul>
            </div>

            <!-- Relationship Banker - Flagstar -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Relationship Banker</h3>
                <span class="text-sm text-muted">March 2019 — August 2023</span>
              </div>
              <p class="text-sm text-muted mb-2">Flagstar Bank — Farmington Hills, MI</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Promoted to Assistant Branch Leader in August 2023.</li>
                <li>Sourced the vast majority of lending origination opportunities for the branch.</li>
                <li>Promoted positive customer experiences by fostering personal and business banking relationships.</li>
                <li>Collaborated with internal partners to ensure customers' needs are met across Mortgage, Business, and Investment services.</li>
                <li>Maintained retail compliance procedures to mitigate fraudulent activity and unnecessary risk.</li>
              </ul>
            </div>

            <!-- Personal Banker - Fifth Third -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Personal Banker</h3>
                <span class="text-sm text-muted">October 2015 — January 2019</span>
              </div>
              <p class="text-sm text-muted mb-2">Fifth Third Bank — West Bloomfield / Pontiac, MI</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Fostered memorable customer experiences by proactively building, maintaining, and growing relationships through various communication channels.</li>
                <li>Applied a consultative approach to uncover and identify customer needs while tailoring recommendations and solutions.</li>
                <li>Collaborated with internal partners to ensure customers' needs were met across banking products.</li>
                <li>Maintained retail procedures to mitigate fraudulent activity and unnecessary risk.</li>
              </ul>
            </div>

            <!-- Store Manager - RadioShack -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Store Manager</h3>
                <span class="text-sm text-muted">June 2011 — October 2015</span>
              </div>
              <p class="text-sm text-muted mb-2">RadioShack — Waterford, MI</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Promoted and supported an environment sharply focused on delivering exceptional customer service.</li>
                <li>Provided supervision and ongoing training of sales associate team; led recruiting, interviewing, and hiring.</li>
                <li>Oversaw physical inventory accuracy including planning, delegation, and execution.</li>
                <li>Developed strategies to reduce store costs while achieving monthly profit goals.</li>
                <li>Maintained relationships with Wireless Account Representatives to promote the RadioShack Mobility initiative.</li>
                <li>Managed wireless contracts for AT&T, Sprint, and Verizon Wireless carriers.</li>
                <li>Ensured cash drawers were balanced and deposits made in a timely fashion.</li>
              </ul>
            </div>

            <!-- Sales Associate - RadioShack -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Sales Associate</h3>
                <span class="text-sm text-muted">June 2009 — June 2011</span>
              </div>
              <p class="text-sm text-muted mb-2">RadioShack — Farmington Hills / Rochester Hills, MI</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Promoted to Store Manager in June 2011.</li>
                <li>Developed relationships with Wireless Account Representatives to promote the RadioShack Mobility initiative.</li>
                <li>Trained fellow associates on wireless promotions, pricing, and proper sales procedures for AT&T, Sprint, and Verizon.</li>
                <li>Ensured cash drawers were balanced and deposits made in a timely fashion.</li>
              </ul>
            </div>

            <!-- Production Crew - WCMU -->
            <div class="mb-10">
              <div class="flex justify-between items-start mb-1">
                <h3 class="h6">Production Crew</h3>
                <span class="text-sm text-muted">September 2005 — May 2009</span>
              </div>
              <p class="text-sm text-muted mb-2">WCMU Public Broadcasting — Mount Pleasant, MI</p>
              <ul class="text-sm space-y-1 list-disc list-outside ml-4">
                <li>Operated cameras, lighting, and audio for WCMU broadcasts.</li>
                <li>Trained other students in camera operation, lighting, and audio control during live broadcasts.</li>
                <li>Served as Production Assistant for shows including Quiz Central, Ask the Specialists, and various special events.</li>
              </ul>
            </div>

          </div>

          <!-- Projects -->
          <div class="mb-12">
            <h2 class="h4 border-b border-border pb-2 mb-6">Projects</h2>
            <p class="text-sm">
              See the <a href="/projects" class="hover:text-primary underline">Projects page</a> for current work.
            </p>
          </div>

          <!-- Contact -->
          <div class="mb-12">
            <h2 class="h4 border-b border-border pb-2 mb-6">Contact</h2>
            <p class="text-sm">
              GitHub: <a
                href="https://github.com/auntiehomie"
                target="_blank"
                rel="noopener"
                class="hover:text-primary">auntiehomie</a
              >
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>
</Base>
